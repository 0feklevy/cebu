# =============================================================================
# deploy/.env  — ORCHESTRATION config for the Docker Compose stack.
# Copy to deploy/.env and fill in.  `docker compose` auto-loads this file for
# ${...} interpolation in docker-compose.yml.
#
# This file does NOT hold app API keys. Those live in the repo-root `.env`
# (see ../.env.example) which the backend/worker containers load via env_file.
# Keep BOTH files off git — deploy/.env is git-ignored below.
# =============================================================================

# ---- Domains / subdomains -----------------------------------------------------
# Create these DNS A-records, all pointing at the VM public IP 44.225.68.155:
#   flowvidco.com        A  44.225.68.155
#   www.flowvidco.com    A  44.225.68.155   (or CNAME -> flowvidco.com)
#   app.flowvidco.com    A  44.225.68.155
#   api.flowvidco.com    A  44.225.68.155
#   admin.flowvidco.com  A  44.225.68.155   (optional)
#
# Routing handled by NGINX:
#   flowvidco.com + www + app  -> client-web (frontend)   [one shared SAN cert]
#   api.flowvidco.com          -> backend (API)
#   admin.flowvidco.com        -> admin-web (optional)
#
# NOTE: keep values on their own line with NO inline comment — some parsers keep
# everything after `=` as the value, which would corrupt domains/cert paths.
# apex + canonical frontend URL + cert lineage name:
DOMAIN_ROOT=flowvidco.com
# -> client-web:
DOMAIN_WWW=www.flowvidco.com
# -> client-web:
DOMAIN_APP=app.flowvidco.com
# -> backend (Fastify API):
DOMAIN_API=api.flowvidco.com
# -> admin-web (optional; leave blank / remove its A-record to skip admin):
DOMAIN_ADMIN=admin.flowvidco.com

# ---- Let's Encrypt ------------------------------------------------------------
# Real address for expiry + security notices:
LETSENCRYPT_EMAIL=you@flowvidco.com
# Set to 1 to use the staging CA while testing (avoids rate limits); 0 for real certs.
LETSENCRYPT_STAGING=0

# ---- Version (managed by deploy.sh / rollback.sh — do not edit by hand) --------
# The git short SHA currently deployed. Images are tagged with this.
APP_VERSION=latest

# ---- Storage (REQUIRED in production — set these in the repo-root .env) --------
# Production is CLOUD-ONLY Supabase Storage. The backend/worker containers set
# STORAGE_BACKEND=supabase (see docker-compose.yml) and FAIL TO START without real
# Supabase S3 credentials — local-disk storage is refused in production. Put these in
# the repo-root .env (loaded via env_file), NOT here:
#   SUPABASE_URL=https://<ref>.supabase.co
#   SUPABASE_STORAGE_BUCKET=<bucket>
#   SUPABASE_S3_ACCESS_KEY_ID=...       (Supabase Storage → S3 access keys)
#   SUPABASE_S3_SECRET_ACCESS_KEY=...
# Also set in the Supabase dashboard: bucket allowed-origins = the app + admin origins.
#
# The public browser-visible origins (BACKEND_API_URL, NEXT_PUBLIC_APP_URL, PUBLIC_SITE_URL,
# ADMIN_ORIGIN) are set from DOMAIN_* by docker-compose.yml — do NOT rely on the root
# .env's localhost defaults for those; compose overrides them for the containers.

# ---- Database -----------------------------------------------------------------
# The database is EXTERNAL (Supabase). There is NO Postgres container.
# Set DATABASE_URL in the repo-root .env (NOT here) — the app + worker load it via env_file.
# IMPORTANT for pg-boss (the worker queue): use Supabase's SESSION-mode pooler (port 5432)
# or the DIRECT connection — NOT the transaction pooler (port 6543), which breaks
# LISTEN/NOTIFY + advisory locks. If you want the web tier on the transaction pooler for
# scale, set DATABASE_URL to :6543 and QUEUE_DATABASE_URL to the :5432 session pooler.

# ---- NGINX --------------------------------------------------------------------
# Max request body (video/audio uploads):
MAX_UPLOAD_SIZE=2g

# ---- Frontend build-time public config (baked into the browser bundle) --------
PUBLIC_BRAND_NAME=Podcast Studio
REVALIDATE_SECRET=change-me-revalidate-secret

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
