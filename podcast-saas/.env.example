# ── Database ──────────────────────────────────────────────────────────────────
# Supabase / hosted Postgres — copy your full connection string from the dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/podcast_saas

# ── Firebase ──────────────────────────────────────────────────────────────────
# Server-side Admin SDK credentials — Firebase Console → Project Settings → Service accounts
# → Generate new private key (downloads a JSON; copy the three fields below from it)
FIREBASE_PROJECT_ID=cebu-1a10f
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@cebu-1a10f.iam.gserviceaccount.com

# Client SDK (public — safe to commit; taken from Firebase Console → Project Settings → General)
NEXT_PUBLIC_FIREBASE_API_KEY=d
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=d
NEXT_PUBLIC_FIREBASE_PROJECT_ID=d
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=d
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=d
NEXT_PUBLIC_FIREBASE_APP_ID=d

# ── LLM API Keys (stored encrypted in DB via admin panel; these are fallbacks) ─
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY also powers the Ask-the-Avatar visual engine (images, charts,
# diagrams, equations, simulations) and conversation memory — keep it set.
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# ── Ask-the-Avatar (Anam) ─────────────────────────────────────────────────────
# Live conversational avatar shown above the video when a viewer clicks "Ask!".
# Ported from darwin-avatar. Einstein is the default persona for every video.
#   1. Create an account at https://lab.anam.ai → Settings → API Keys
#   2. Create a persona for each character; copy its persona UUID below
# Without ANAM_API_KEY + a persona, the popup shows a "not configured" message
# but the rest of the app (and the visual Library generation) still works.
ANAM_API_KEY=
# Default persona used for all videos (Einstein). ANAM_PERSONA_ID is a legacy
# fallback used when the per-character ID is unset.
ANAM_PERSONA_ID_EINSTEIN=
ANAM_PERSONA_ID=
# Optional additional characters
ANAM_PERSONA_ID_DARWIN=
ANAM_PERSONA_ID_NAPOLEON=
ANAM_PERSONA_ID_ARCHIMEDES=

# ── ElevenLabs (TTS voice synthesis) ──────────────────────────────────────────
# Set this in the Admin panel → API Keys → ElevenLabs (recommended)
# OR set here as a fallback env var (not used by the app directly — admin panel stores it encrypted in DB)
# Get your key at: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Optional overrides for the guided-simulation TTS voice/model.
# If unset, the app falls back to the admin-panel voice and eleven_multilingual_v2.
GUIDANCE_TTS_VOICE_ID=
GUIDANCE_TTS_MODEL=

# ── AI Video Generation (B-roll) ─────────────────────────────────────────────
# Kling 3.0 (Kuaishou) — https://klingai.com/global/api
# Create credentials in the Kling developer portal → API Keys
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# Seedance 2.0 (BytePlus ModelArk) — https://docs.byteplus.com/en/docs/ModelArk
# Create an API key in the BytePlus ModelArk console
SEEDANCE_API_KEY=your-bytedance-ark-api-key

# Veo 3 (Google) — uses GOOGLE_GENERATIVE_AI_API_KEY already set above.
# Enable "Generative Language API" in Google Cloud Console and ensure your key
# has access to veo-3.0-generate-preview (may require waitlist approval).
# No additional key needed — GOOGLE_GENERATIVE_AI_API_KEY covers Veo.

# ── Storage backend selection ──────────────────────────────────────────────────
# Optional explicit override: 'supabase' | 'r2' | 'local'. If unset, Supabase Storage
# is used when its S3 creds below are present, else R2 (if real creds), else local disk.
STORAGE_BACKEND=

# ── Storage (Supabase Storage — S3-compatible, the writable provider) ───────────
# Create a bucket in Supabase → Storage, then generate S3 access keys in
# Storage → Settings → S3 access keys. SUPABASE_URL is your project URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_S3_ACCESS_KEY_ID=your-supabase-s3-access-key
SUPABASE_S3_SECRET_ACCESS_KEY=your-supabase-s3-secret
SUPABASE_S3_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=media
# Optional — defaults to ${SUPABASE_URL}/storage/v1/s3
SUPABASE_S3_ENDPOINT=

# ── Storage (Cloudflare R2 — currently read-only token; kept as fallback) ───────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=podcast-saas
R2_PUBLIC_URL=https://pub.r2.dev/podcast-saas

# ── Encryption (for API key storage) ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-key-here-change-in-prod

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Pay-to-unlock locked videos and playlists. Get keys at https://dashboard.stripe.com/apikeys
# Leave STRIPE_SECRET_KEY blank to disable billing entirely (paywall hidden, lock UI hidden).
STRIPE_SECRET_KEY=sk_test_...
# Public key — also expose to the frontend as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY below.
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — from `stripe listen` (dev) or the Dashboard → Webhooks (prod).
# Endpoint: POST {BACKEND_API_URL}/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform commission kept on each sale (0–100). The creator receives the rest.
PLATFORM_FEE_PERCENT=15

# ── Trigger.dev ───────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# ── Ingestion services ────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...
GROQ_API_KEY=gsk_...

# Optional PDF extraction backends (used by PDFIngester as fallbacks; leave blank
# to disable). DOCLING_URL points at a running Docling HTTP service; LlamaParse
# is a hosted parsing API (https://cloud.llamaindex.ai).
DOCLING_URL=
LLAMAPARSE_API_KEY=

# ── Dev only ──────────────────────────────────────────────────────────────────
# Used by client-web dev helper scripts (dev-check / dev-watch); not needed at runtime.
PROJECT_ID=

# ── App URLs ──────────────────────────────────────────────────────────────────
# BACKEND_API_URL must be the backend's PUBLIC origin in production: simulation files
# are served to the browser through this origin's /sim-public/* proxy (Supabase's public
# bucket force-downgrades text/html → text/plain, so an iframe can't load the bucket URL
# directly). If unset in prod, sim iframes resolve to http://localhost:8080 and break.
BACKEND_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_API_URL=http://localhost:8080

# ── Course publishing (Phase 2) ───────────────────────────────────────────────
# Public canonical host for /c/ course & lesson URLs, sitemaps, OG images AND
# creator permalinks ({PUBLIC_SITE_URL}/{slug}, migration 043). Point this at the
# real domain (e.g. https://science-of-awe.com) when deploying — permalinks and
# canonical URLs follow it automatically.
# Falls back to NEXT_PUBLIC_APP_URL when unset. Used by backend + client-web.
PUBLIC_SITE_URL=http://localhost:3000
# Brand name used in SEO fallbacks, JSON-LD Organization and OG images.
PUBLIC_BRAND_NAME=Interactive Video Studio
# Conditional legacy /v and /pl → /c redirects. Keep DISABLED until the new /c
# pages are manually verified in each environment.
COURSE_LEGACY_REDIRECTS_ENABLED=false
# On-demand revalidation webhook (client-web /api/revalidate). Backend posts
# invalidation targets here on course/lesson change. Leave URL unset to no-op.
REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=change-me

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated emails that are auto-granted admin on every login (no SQL needed)
ADMIN_EMAILS=your-email@gmail.com

# ── Admin panel auth bypass (dev only) ────────────────────────────────────────
# Default is bypass ON (no access check). Set to 'false' to enforce admin-only.
NEXT_PUBLIC_ADMIN_BYPASS=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info