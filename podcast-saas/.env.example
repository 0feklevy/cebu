# ── Database ──────────────────────────────────────────────────────────────────
# Supabase / hosted Postgres — copy your full connection string from the dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/podcast_saas

# ── Firebase ──────────────────────────────────────────────────────────────────
# Server-side Admin SDK credentials — Firebase Console → Project Settings → Service accounts
# → Generate new private key (downloads a JSON; copy the three fields below from it)
FIREBASE_PROJECT_ID=cebu-1a10f
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@cebu-1a10f.iam.gserviceaccount.com

# Client SDK (public — safe to commit; taken from Firebase Console → Project Settings → General)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCs-xu4cejlxxVcSLFWM0MzCVYG_QZ2weg
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cebu-1a10f.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cebu-1a10f
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cebu-1a10f.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=380315031504
NEXT_PUBLIC_FIREBASE_APP_ID=1:380315031504:web:4d4b5f3b1ec6628950cbd5

# ── LLM API Keys (stored encrypted in DB via admin panel; these are fallbacks) ─
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# ── ElevenLabs (TTS voice synthesis) ──────────────────────────────────────────
# Set this in the Admin panel → API Keys → ElevenLabs (recommended)
# OR set here as a fallback env var (not used by the app directly — admin panel stores it encrypted in DB)
# Get your key at: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Optional overrides for the guided-simulation TTS voice/model.
# If unset, the app falls back to the admin-panel voice and eleven_multilingual_v2.
GUIDANCE_TTS_VOICE_ID=
GUIDANCE_TTS_MODEL=

# ── AI Video Generation (B-roll) ─────────────────────────────────────────────
# Kling 3.0 (Kuaishou) — https://klingai.com/global/api
# Create credentials in the Kling developer portal → API Keys
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# Seedance 2.0 (BytePlus ModelArk) — https://docs.byteplus.com/en/docs/ModelArk
# Create an API key in the BytePlus ModelArk console
SEEDANCE_API_KEY=your-bytedance-ark-api-key

# Veo 3 (Google) — uses GOOGLE_GENERATIVE_AI_API_KEY already set above.
# Enable "Generative Language API" in Google Cloud Console and ensure your key
# has access to veo-3.0-generate-preview (may require waitlist approval).
# No additional key needed — GOOGLE_GENERATIVE_AI_API_KEY covers Veo.

# ── Storage (Cloudflare R2) ────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=podcast-saas
R2_PUBLIC_URL=https://pub.r2.dev/podcast-saas

# ── Encryption (for API key storage) ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-key-here-change-in-prod

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Pay-to-unlock locked videos and playlists. Get keys at https://dashboard.stripe.com/apikeys
# Leave STRIPE_SECRET_KEY blank to disable billing entirely (paywall hidden, lock UI hidden).
STRIPE_SECRET_KEY=sk_test_...
# Public key — also expose to the frontend as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY below.
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — from `stripe listen` (dev) or the Dashboard → Webhooks (prod).
# Endpoint: POST {BACKEND_API_URL}/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform commission kept on each sale (0–100). The creator receives the rest.
PLATFORM_FEE_PERCENT=15

# ── Trigger.dev ───────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# ── Ingestion services ────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...
GROQ_API_KEY=gsk_...

# Optional PDF extraction backends (used by PDFIngester as fallbacks; leave blank
# to disable). DOCLING_URL points at a running Docling HTTP service; LlamaParse
# is a hosted parsing API (https://cloud.llamaindex.ai).
DOCLING_URL=
LLAMAPARSE_API_KEY=

# ── Dev only ──────────────────────────────────────────────────────────────────
# Used by client-web dev helper scripts (dev-check / dev-watch); not needed at runtime.
PROJECT_ID=

# ── App URLs ──────────────────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_API_URL=http://localhost:8080

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated emails that are auto-granted admin on every login (no SQL needed)
ADMIN_EMAILS=your-email@gmail.com

# ── Admin panel auth bypass (dev only) ────────────────────────────────────────
# Default is bypass ON (no access check). Set to 'false' to enforce admin-only.
NEXT_PUBLIC_ADMIN_BYPASS=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info